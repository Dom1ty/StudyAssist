{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Study Assistant (Streamlit)",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "app.py"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}\\.env",
      "justMyCode": true
    }
  ]
}
